generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Laporan {
  id           Int      @id @default(autoincrement())
  teks_asli    String
  teks_bersih  String?
  nama         String?
  lokasi       String?
  kategori     String?
  sentimen     String?
  skor_urgensi Int?
  confidence   Float?
  tanggal      DateTime @default(now())
}
