# ===== LaporIn Backend — Environment Variables =====

# Database PostgreSQL (Railway / Neon / Supabase)
DATABASE_URL="postgresql://user:password@host:5432/laporin?schema=public"

# HuggingFace Spaces API (AI Inference)
# URL endpoint POST /predict di HuggingFace Space kamu
HUGGINGFACE_API_URL="https://your-username-your-space.hf.space/predict"

# HuggingFace API Token (opsional, untuk Space private)
HUGGINGFACE_API_TOKEN=""

# Port server (default: 3000)
PORT=3000
